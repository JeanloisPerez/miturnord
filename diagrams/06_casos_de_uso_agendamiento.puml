@startuml 06 - Casos de Uso - Agendamiento
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Helvetica Neue"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundcorner 8

skinparam usecase {
  BackgroundColor #E8F4FD
  BorderColor #1565C0
  BorderThickness 1.5
  FontColor #0D47A1
}

skinparam actor {
  BackgroundColor #FFF3E0
  BorderColor #E65100
  FontColor #BF360C
}

skinparam rectangle {
  BorderColor #546E7A
  BorderThickness 1.5
  BackgroundColor #FAFAFA
}

title <size:18><b>MiTurnoRD — Casos de Uso</b></size>\n<size:12>Proceso de Agendamiento de Citas</size>

actor "Cliente\n(Usuario Final)" as Client
actor "Propietario\n(Owner)" as Owner
actor "Sistema\n(Backend / Cron)" as System

rectangle "MiTurnoRD — Módulo de Agendamiento" {

  usecase "Registrarse / Iniciar sesión" as UC_LOGIN
  usecase "Buscar institución" as UC_SEARCH
  usecase "Ver detalle de\ninstitución y sucursal" as UC_DETAIL
  usecase "Ver slots disponibles" as UC_SLOTS
  usecase "Seleccionar fecha y hora" as UC_SELECT
  usecase "Completar campos\npersonalizados" as UC_FIELDS
  usecase "Confirmar cita" as UC_CONFIRM
  usecase "Ver mis citas" as UC_MYAPPTS
  usecase "Cancelar cita" as UC_CANCEL
  usecase "Reagendar cita" as UC_RESCHEDULE

  usecase "Validar disponibilidad\n(Motor de slots)" as UC_ENGINE
  usecase "Aplicar reglas\nde negocio" as UC_RULES
  usecase "Guardar cita\nen BD" as UC_SAVE
  usecase "Enviar email\nde confirmación" as UC_EMAIL
  usecase "Enviar recordatorio\nautomático" as UC_REMINDER

  usecase "Ver citas\nde clientes" as UC_OWNER_VIEW
  usecase "Confirmar cita\npendiente" as UC_OWNER_CONFIRM
  usecase "Cancelar / completar\ncita" as UC_OWNER_CANCEL
  usecase "Gestionar tiempos\nbloqueados" as UC_OWNER_BLOCK
}

' ─── Relaciones del Cliente ───────────────────
Client --> UC_LOGIN
Client --> UC_SEARCH
Client --> UC_DETAIL
Client --> UC_SLOTS
Client --> UC_SELECT
Client --> UC_FIELDS
Client --> UC_CONFIRM
Client --> UC_MYAPPTS
Client --> UC_CANCEL
Client --> UC_RESCHEDULE

' ─── Relaciones del Propietario ───────────────
Owner --> UC_OWNER_VIEW
Owner --> UC_OWNER_CONFIRM
Owner --> UC_OWNER_CANCEL
Owner --> UC_OWNER_BLOCK

' ─── Relaciones del Sistema ───────────────────
System --> UC_ENGINE
System --> UC_RULES
System --> UC_SAVE
System --> UC_EMAIL
System --> UC_REMINDER

' ─── Includes / Extends ───────────────────────
UC_CONFIRM ..> UC_ENGINE : <<include>>
UC_CONFIRM ..> UC_RULES : <<include>>
UC_CONFIRM ..> UC_SAVE : <<include>>
UC_CONFIRM ..> UC_EMAIL : <<extend>>\n[si auto_confirm=true\ny hay email]

UC_RESCHEDULE ..> UC_ENGINE : <<include>>
UC_RESCHEDULE ..> UC_EMAIL : <<extend>>\n[si reprogramación exitosa]

UC_SLOTS ..> UC_ENGINE : <<include>>
UC_SLOTS ..> UC_RULES : <<include>>

UC_FIELDS ..> UC_CONFIRM : <<include>>\n[campos requeridos]

UC_OWNER_CONFIRM ..> UC_EMAIL : <<extend>>\n[notifica al cliente]

UC_REMINDER ..> UC_EMAIL : <<include>>

@enduml
