@startuml 04 - Flujos Clave
!theme plain
skinparam backgroundColor #FAFAFA
skinparam roundcorner 10
skinparam defaultFontName "Helvetica Neue"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam sequenceArrowThickness 1.5

title <size:18><b>MiTurnoRD — Flujos Clave</b></size>\n<size:12>Agendamiento · Reagendamiento · Recordatorios</size>

skinparam participant {
  BackgroundColor #E8F4FD
  BorderColor #1565C0
  FontColor #0D47A1
}

skinparam actor {
  BackgroundColor #FFF3E0
  BorderColor #E65100
}

'═══════════════════════════════════
' FLUJO 1 — Agendamiento de cita
'═══════════════════════════════════
actor Cliente as C
participant "Frontend" as FE
participant "AppointmentsModule" as AM
participant "SchedulingEngine" as SE
participant "BusinessRules" as BR
participant "Schedules /\nBlockedTimes" as SB
participant "EmailsModule" as EM
database "PostgreSQL" as DB

== Flujo 1: Agendar Cita ==

C -> FE : Selecciona institución,\nsucursal, servicio y fecha
FE -> AM : POST /appointments\n{date, serviceId, branchId}
AM -> SE : getAvailableSlots(\n  date, branchId, serviceId)
SE -> SB : consulta horarios\n+ bloqueos de esa fecha
SE -> BR : carga reglas\n(buffer, maxPerSlot, avanceDays)
SE -> DB : excluye citas existentes
SE --> AM : lista de slots libres
AM -> DB : crea Appointment (PENDING o CONFIRMED)
AM -> EM : sendConfirmationEmail(user, appointment)
EM --> C : 📧 Email de confirmación
AM --> FE : 201 Created · { appointment }
FE --> C : "Cita confirmada ✓"

== Flujo 2: Reagendar Cita ==

C -> FE : Selecciona nueva fecha/hora
FE -> AM : PATCH /appointments/:id/reschedule\n{newDate}
AM -> SE : verifica disponibilidad\n(excluyendo la cita actual)
SE --> AM : slot válido
AM -> DB : crea nueva Appointment (RESCHEDULED)\nupdatea anterior
AM -> EM : sendRescheduleEmail(user, newAppointment)
EM --> C : 📧 Email de reagendamiento
AM --> FE : 200 OK
FE --> C : "Cita reagendada ✓"

== Flujo 3: Recordatorio Automático (Cron) ==

participant "RemindersModule\n(Cron Job)" as RM
participant "SystemSettings" as SS

RM -> SS : lee cron_reminder_frequency_minutes
SS --> RM : ej. cada 60 min
RM -> DB : busca citas mañana\ncon reminder_sent = false
DB --> RM : lista de citas
RM -> EM : sendReminderEmail()\npor cada cita
EM --> C : 📧 Recordatorio 24h antes
RM -> DB : marca reminder_sent = true

@enduml
