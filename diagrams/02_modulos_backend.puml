@startuml 02 - Modulos del Backend
!theme plain
skinparam backgroundColor #FAFAFA
skinparam roundcorner 10
skinparam defaultFontName "Helvetica Neue"
skinparam defaultFontSize 12
skinparam shadowing false

title <size:18><b>MiTurnoRD — Módulos del Backend</b></size>\n<size:12>NestJS · 18 módulos agrupados por responsabilidad</size>

skinparam rectangle {
  BorderThickness 2
}

skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #78909C
  BorderThickness 1.5
}

package "🔐 Autenticación & Usuarios" as AUTH #E3F2FD {
  component "AuthModule\nJWT · Guards · Roles" as AuthM
  component "UsersModule\nCRUD de usuarios" as UsersM
}

package "🏢 Núcleo Multi-Tenant" as CORE #E8F5E9 {
  component "InstitutionsModule" as InstM
  component "InstitutionTypesModule" as TypesM
  component "BranchesModule\n(Sucursales)" as BranchM
  component "ServicesModule" as ServM
  component "CustomFieldsModule\n(Campos dinámicos)" as FieldM
}

package "⏰ Motor de Disponibilidad" as ENGINE #FFF8E1 {
  component "SchedulesModule\n(Horarios semanales)" as SchedM
  component "BlockedTimesModule\n(Bloqueos manuales)" as BlockM
  component "BusinessRulesModule\n(Reglas de negocio)" as RulesM
  component "SchedulingEngineModule\n(Cálculo de slots)" as EngineM
}

package "📅 Gestión de Citas" as APPTS #FCE4EC {
  component "AppointmentsModule\nCRUD · Reagendar" as ApptM
  component "ReportsModule\nEstadísticas" as ReportM
}

package "🔧 Servicios Transversales" as SUPPORT #F3E5F5 {
  component "EmailsModule\nnodemailer SMTP" as EmailM
  component "RemindersModule\nCron Job" as ReminderM
  component "UploadModule\nMultipart" as UploadM
  component "SystemSettingsModule\nConfig SaaS" as SettingsM
}

component "PrismaModule\nORM · PostgreSQL" as PrismaM #EDE7F6

' Flujos internos clave
ApptM --> EngineM : "verifica\ndisponibilidad"
EngineM ..> SchedM : "lee horarios"
EngineM ..> BlockM : "excluye bloques"
EngineM ..> RulesM : "aplica reglas"
EngineM ..> ApptM : "excluye citas\nexistentes"
ApptM --> EmailM : "confirma /\ncancela"
ReminderM --> EmailM : "recordatorio\ncron"
ReminderM ..> SettingsM : "frecuencia"
ServM ..> BranchM : "asigna servicios"

' Todos pasan por Prisma
AUTH ..> PrismaM
CORE ..> PrismaM
ENGINE ..> PrismaM
APPTS ..> PrismaM
ReminderM ..> PrismaM
UploadM ..> PrismaM

@enduml
