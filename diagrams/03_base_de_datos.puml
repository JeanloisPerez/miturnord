@startuml 03 - Base de Datos
!theme plain
skinparam backgroundColor #FAFAFA
skinparam roundcorner 8
skinparam defaultFontName "Helvetica Neue"
skinparam defaultFontSize 11
skinparam shadowing false

title <size:18><b>MiTurnoRD — Modelo de Datos</b></size>\n<size:12>PostgreSQL · Prisma ORM · Multi-Tenant</size>

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #546E7A
  BorderThickness 1.5
  HeaderBackgroundColor #E8F4FD
  HeaderFontColor #0D47A1
  FontColor #212121
}

' ─── AUTH ──────────────────────────────────────
class User {
  + id : UUID (PK)
  + full_name : String
  + email : String? (unique)
  + phone : String? (unique)
  + document_id : String?
  + password_hash : String
  + status : UserStatus
  + created_at / updated_at
}

class Role {
  + id : Int (PK)
  + name : String (unique)
}

class UserRole {
  + user_id (FK)
  + role_id (FK)
}

class AuthSession {
  + id : UUID (PK)
  + user_id (FK)
  + token : String
  + expires_at : DateTime
}

class SaasAdmin {
  + id : UUID (PK)
  + email : String (unique)
  + password_hash : String
}

' ─── INSTITUTION ───────────────────────────────
class InstitutionType {
  + id : UUID (PK)
  + name : String (unique)
  + description : String?
  + icon : String?
}

class Institution {
  + id : UUID (PK)
  + name : String
  + slug : String (unique)
  + logo_url : String?
  + address, phone, email
  + institution_type_id (FK)
  + status : InstitutionStatus
}

class InstitutionUser {
  + id : UUID (PK)
  + institution_id (FK)
  + user_id (FK)
  + role : OWNER | STAFF | MANAGER
}

' ─── BRANCH & SERVICE ──────────────────────────
class Branch {
  + id : UUID (PK)
  + institution_id (FK)
  + name, address, city, phone
  + latitude, longitude
  + is_main : Boolean
  + active : Boolean
}

class Service {
  + id : UUID (PK)
  + institution_id (FK)
  + name, description
  + duration : Int (minutes)
  + price : Decimal?
  + active : Boolean
}

class BranchService {
  + branch_id (FK) (PK)
  + service_id (FK) (PK)
  + active : Boolean
}

' ─── SCHEDULING ────────────────────────────────
class Schedule {
  + id : UUID (PK)
  + institution_id (FK)
  + branch_id (FK)?
  + day_of_week : Int (0-6)
  + start_time / end_time : String
  + active : Boolean
}

class BlockedTime {
  + id : UUID (PK)
  + branch_id (FK)
  + date : Date
  + start_time / end_time : String
  + reason : String?
}

class BusinessRule {
  + id : UUID (PK)
  + institution_id (FK, unique)
  + auto_confirm : Boolean
  + buffer_minutes : Int
  + max_per_slot : Int
  + no_show_minutes : Int
  + advance_book_days : Int
  + reminder_days_before : Int
}

' ─── APPOINTMENT ───────────────────────────────
class Appointment {
  + id : UUID (PK)
  + date : DateTime
  + status : AppointmentStatus
  + institution_id (FK)
  + service_id (FK)
  + user_id (FK)
  + branch_id (FK)?
  + rescheduled_from_id : UUID?
  + reminder_sent : Boolean
}

class CustomField {
  + id : UUID (PK)
  + label, placeholder
  + field_type : FieldType
  + required : Boolean
  + institution_id (FK)
  + service_id (FK)?
}

class AppointmentFieldResponse {
  + id : UUID (PK)
  + appointment_id (FK)
  + field_id (FK)
  + value : String
}

class ReminderLog {
  + id : UUID (PK)
  + appointment_id
  + user_email
  + status : SUCCESS | FAILED
}

class SystemSetting {
  + id : "singleton"
  + cron_reminder_frequency_minutes
  + log_retention_days
}

' ─── RELACIONES ────────────────────────────────
User "1" --o{ "n" UserRole
Role "1" --o{ "n" UserRole
User "1" --o{ "n" AuthSession
User "1" --o{ "n" InstitutionUser
User "1" --o{ "n" Appointment

InstitutionType "1" --o{ "n" Institution
Institution "1" --o{ "n" InstitutionUser
Institution "1" --o{ "n" Branch
Institution "1" --o{ "n" Service
Institution "1" --o{ "n" Schedule
Institution "1" --o{ "n" Appointment
Institution "1" --o| "1" BusinessRule
Institution "1" --o{ "n" CustomField

Branch "1" --o{ "n" BranchService
Branch "1" --o{ "n" Schedule
Branch "1" --o{ "n" BlockedTime
Branch "1" --o{ "n" Appointment

Service "1" --o{ "n" BranchService
Service "1" --o{ "n" Appointment
Service "1" --o{ "n" CustomField

Appointment "1" --o{ "n" AppointmentFieldResponse
CustomField "1" --o{ "n" AppointmentFieldResponse

@enduml
