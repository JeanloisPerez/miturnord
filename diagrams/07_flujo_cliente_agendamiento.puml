@startuml 07 - Flujo Cliente Agendamiento
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Helvetica Neue"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam roundcorner 10
skinparam arrowColor #1565C0
skinparam arrowThickness 1.8

skinparam activity {
  BackgroundColor #E8F4FD
  BorderColor #1565C0
  BorderThickness 1.5
  FontColor #0D47A1
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #F57F17
  DiamondFontColor #BF360C
  StartColor #1565C0
  EndColor #1B5E20
}

skinparam note {
  BackgroundColor #F3E5F5
  BorderColor #7B1FA2
  FontColor #4A148C
}

title <size:17><b>MiTurnoRD — Flujo de Agendamiento de Cita</b></size>\n<size:11>Perspectiva del cliente</size>

start

:Usuario inicia sesión\n(o se registra si es nuevo);

note right
  Autenticación JWT.
  Si no tiene cuenta,
  se registra primero.
end note

:Busca y selecciona institución;

:Selecciona sucursal\n(si la institución tiene varias);

:Selecciona el servicio\nque desea agendar;

:Sistema consulta disponibilidad\n(horarios + bloqueos + reglas de negocio);

:Usuario selecciona fecha y hora\ndel calendario de slots disponibles;

:Usuario completa campos\npersonalizados requeridos;

note right
  Ejemplo: cédula, motivo
  de consulta, archivos, etc.
  Cada institución define los suyos.
end note

:Usuario confirma la cita;

:Sistema verifica disponibilidad\nen tiempo real\n(vacantes, horario, anticipación máxima);

if (¿Horario disponible?) then (NO)
  :Mostrar mensaje de\nhorario no disponible;
  :Sugerir horarios\nalternativos cercanos;
  :Usuario selecciona\notro horario;
  note right
    El backend retorna
    una lista de alternativas
    automáticamente.
  end note
  detach
else (SÍ)
endif

:Registrar cita en\nBase de Datos;

note right
  Estado: CONFIRMED
  (si auto_confirm = true)
  o PENDING si el propietario
  debe confirmar manualmente.
end note

if (¿auto_confirm = true?) then (SÍ)
  :Enviar email de confirmación\nal usuario;
  note right
    Email con: fecha, hora,
    servicio e institución.
    Enviado vía SMTP.
  end note
else (NO — queda PENDING)
  :Propietario recibe cita\nen su panel administrativo;
  :Propietario confirma\nmanualmente;
  :Sistema envía email\nde confirmación al cliente;
endif

:Panel administrativo\nse actualiza con la nueva cita\n(visible para el propietario);

:Sistema programa recordatorio\nautomático (24h antes)\nvía cron job;

:Usuario visualiza su cita\nen "Mis Citas"\ncon estado y detalles;

stop

@enduml
