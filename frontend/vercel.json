{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://miturnord-backend.vercel.app/api/$1"
    },
    {
      "source": "/upload/(.*)",
      "destination": "https://miturnord-backend.vercel.app/upload/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}